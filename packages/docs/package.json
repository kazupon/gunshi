{
  "name": "@gunshi/docs",
  "description": "Documentation for gunshi",
  "version": "0.35.1",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazupon/gunshi.git",
    "directory": "packages/docs"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm run build:api && pnpm run build:readme && pnpm run build:vitepress",
    "build:api": "tsx ./scripts/clean-api.ts",
    "build:readme": "pnpm run generate",
    "build:vitepress": "vitepress build src",
    "generate": "tsx ./scripts/generate.ts",
    "dev": "pnpm run build:api && vitepress dev src",
    "preview": "vitepress preview src"
  },
  "keywords": [
    "command",
    "option",
    "cli",
    "argument",
    "args",
    "argv",
    "docs",
    "documentation",
    "llms"
  ],
  "bin": {
    "gunshi-docs-init": "./bin/init.js"
  },
  "files": [
    "bin",
    "README.md",
    "src/api",
    "src/guide",
    "src/release",
    "src/index.md",
    "src/showcase.md"
  ],
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "tinyexec": "^1.0.2"
  },
  "devDependencies": {
    "@gunshi/plugin-i18n": "workspace:*",
    "@gunshi/plugin-renderer": "workspace:*",
    "@types/node": "catalog:",
    "@vueuse/core": "^14.0.0",
    "args-tokens": "catalog:",
    "mermaid": "^11.12.0",
    "oxc-minify": "^0.137.0",
    "tsx": "catalog:",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-api-references": "catalog:",
    "vitepress-plugin-group-icons": "^1.5.5",
    "vitepress-plugin-llms": "^1.3.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.14"
  }
}
